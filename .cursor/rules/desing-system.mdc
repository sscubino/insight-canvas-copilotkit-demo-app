<!-- 06 — INTERACTION FLOWS -->
<div class="section">
  <div class="section-header">
    <span class="section-num">06</span>
    <h2 class="section-title">Interaction Flows</h2>
    <div class="section-rule"></div>
  </div>

  <div class="flow-diagram">
    <div class="flow-title">Flow 1 — Generate Insights from scratch <span class="flow-badge f1">PRIMARY FLOW</span></div>
    <div class="flow-steps">
      <div class="flow-step"><div class="step-box user-box"><div class="step-actor user">User</div><div class="step-action">Opens app</div><div class="step-detail">Empty canvas. Sidebar shows past sessions.</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box user-box"><div class="step-actor user">User</div><div class="step-action">Selects dataset</div><div class="step-detail">Opens drawer, picks "SaaS Churn Dataset"</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box user-box"><div class="step-actor user">User</div><div class="step-action">Types a prompt</div><div class="step-detail">"Identify churn risk patterns"</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box agent-box"><div class="step-actor agent">Agent</div><div class="step-action">Analyzes via MCP</div><div class="step-detail">Calls mcp_chart_generator and mcp_stats</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box result-box"><div class="step-actor canvas">Canvas</div><div class="step-action">3 connected nodes appear</div><div class="step-detail">Chart → Insight → Hypothesis, animated sequentially</div></div></div>
    </div>
    <div class="flow-notes">
      <div class="flow-note"><strong>Initial state:</strong> empty canvas, agent on standby</div>
      <div class="flow-note"><strong>Final state:</strong> Chart→Insight→Hypothesis chain visible</div>
      <div class="flow-note"><strong>Animation:</strong> nodes appear one by one with fade-in</div>
    </div>
  </div>

  <div class="flow-diagram">
    <div class="flow-title">Flow 2 — Co-creation: user edits, agent responds <span class="flow-badge f2">CO-CREATION</span></div>
    <div class="flow-steps">
      <div class="flow-step"><div class="step-box user-box"><div class="step-actor user">User</div><div class="step-action">Clicks Hypothesis node</div><div class="step-detail">Side detail panel opens</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box user-box"><div class="step-actor user">User</div><div class="step-action">Edits hypothesis text</div><div class="step-detail">Adds: "specifically on day 3 of onboarding"</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box agent-box"><div class="step-actor agent">Agent</div><div class="step-action">Detects change</div><div class="step-detail">Checks coherence with existing insight</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box result-box"><div class="step-actor canvas">Canvas</div><div class="step-action">Generates Experiment node</div><div class="step-detail">+ supporting chart, both connect to the edited hypothesis</div></div></div>
    </div>
    <div class="flow-notes">
      <div class="flow-note"><strong>Trigger:</strong> agent reacts when a node is saved after editing</div>
      <div class="flow-note"><strong>Final state:</strong> chain extends → Hypothesis → Experiment + support chart</div>
    </div>
  </div>

  <div class="flow-diagram">
    <div class="flow-title">Flow 3 — Full reasoning chain <span class="flow-badge f3">FULL CHAIN</span></div>
    <div class="flow-steps">
      <div class="flow-step"><div class="step-box result-box"><div class="step-actor canvas">Canvas</div><div class="step-action">Chart</div><div class="step-detail">Data visualization</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box agent-box"><div class="step-actor agent">Agent</div><div class="step-action">Insight</div><div class="step-detail">Data-driven observation</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box user-box"><div class="step-actor user">User + Agent</div><div class="step-action">Hypothesis</div><div class="step-detail">Edited by user, refined by agent</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box agent-box"><div class="step-actor agent">Agent</div><div class="step-action">Experiment</div><div class="step-detail">Test plan with metrics</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box system-box"><div class="step-actor output">Output</div><div class="step-action">Action Item</div><div class="step-detail">Exportable operational task</div></div></div>
    </div>
    <div class="flow-notes">
      <div class="flow-note"><strong>Visual output:</strong> horizontal chain, readable on projection screens</div>
      <div class="flow-note"><strong>User can:</strong> reorder, add parallel branches, zoom in/out</div>
    </div>
  </div>

  <div class="flow-diagram">
    <div class="flow-title">Flow 4 — Return and cross-session memory <span class="flow-badge f4">PERSISTENCE</span></div>
    <div class="flow-steps">
      <div class="flow-step"><div class="step-box user-box"><div class="step-actor user">User</div><div class="step-action">Returns to the app</div><div class="step-detail">Days after previous session</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box agent-box"><div class="step-actor agent">Agent</div><div class="step-action">Shows memory banner</div><div class="step-detail">"Previously we identified churn in week 3..."</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box user-box"><div class="step-actor user">User</div><div class="step-action">Opens previous session</div><div class="step-detail">Canvas loads with all prior nodes intact</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box agent-box"><div class="step-actor agent">Agent</div><div class="step-action">Highlights chain + proposes next step</div><div class="step-detail">"Want to analyze mobile vs desktop?"</div></div></div>
      <div class="step-arrow"><div class="arrow-line"></div></div>
      <div class="flow-step"><div class="step-box result-box"><div class="step-actor canvas">Canvas</div><div class="step-action">Canvas expands</div><div class="step-detail">New branch added to existing analysis</div></div></div>
    </div>
    <div class="flow-notes">
      <div class="flow-note"><strong>Thread persistence:</strong> each session saved as a complete thread</div>
      <div class="flow-note"><strong>Cross-session memory:</strong> agent recalls insights, not just messages</div>
    </div>
  </div>
</div>

