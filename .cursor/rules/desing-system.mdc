      </div>
      <div class="canvas-area">
        <div class="node insight" style="left:72px;top:126px;box-shadow:0 0 0 2px var(--insight),0 4px 20px #05966920;">
          <div class="node-type">Insight</div>
          <div class="node-title">Churn spike in week 3</div>
          <div class="node-body">40% of churned users leave before day 21.</div>
          <div class="node-footer">Selected</div>
        </div>
        <div class="node chart" style="left:272px;top:70px;opacity:0.35;">
          <div class="node-type">Chart</div>
          <div class="node-title">Churn by week</div>
          <div class="node-footer">MCP App</div>
        </div>
        <div class="node hypo" style="left:184px;top:284px;opacity:0.35;">
          <div class="node-type">Hypothesis</div>
          <div class="node-title">Onboarding doesn't show value</div>
          <div class="node-footer">Edited</div>
        </div>
      </div>
      <div class="detail-panel">
        <div class="detail-header">
          <div class="detail-node-type insight"><span style="width:7px;height:7px;background:var(--insight);border-radius:50%;display:inline-block;"></span>Insight</div>
          <div class="detail-title">Churn spike in week 3</div>
        </div>
