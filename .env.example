# Anthropic API key for CopilotKit runtime
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Anthropic model for session title generation and memory summary
ANTHROPIC_FAST_MODEL=claude-haiku-4-5

# CopilotKit runtime model (<provider>/<model>)
COPILOTKIT_BUILT_IN_AGENT_MODEL=anthropic/claude-sonnet-4-6